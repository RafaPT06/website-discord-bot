# Used by npm run monitor locally.
# Do not commit your real webhook URL.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE_ME/REPLACE_ME
MEOWZ_BASE_URL=https://meowz.up.railway.app
MONITOR_WAIT_MS=7000

# Optional fallback for dashboard channel dropdowns.
# Preferred: expose GET /api/guilds/:guildId/channels from the bot API configured by BOT_API_URL.
# Fallback: set this on the website Railway service so the website can read guild channels directly.
DISCORD_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN
BOT_API_URL=https://your-bot-api.example.com
BOT_API_TOKEN=REPLACE_WITH_SHARED_API_TOKEN
