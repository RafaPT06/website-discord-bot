# Copy this file to .env for local development, then replace required placeholders.
# Never commit the real .env file or real credentials.

# Required: internal bot API connection.
BOT_API_URL=http://localhost:3001
BOT_API_TOKEN=replace_with_shared_bot_api_token

# Required: Discord OAuth application and signed website sessions.
DISCORD_CLIENT_ID=replace_with_discord_client_id
DISCORD_CLIENT_SECRET=replace_with_discord_client_secret
SESSION_SECRET=replace_with_long_random_session_secret

# Optional locally; defaults to the current website origin plus /auth/discord/callback.
# Set explicitly in Railway to the deployed callback registered in Discord.
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# Optional server configuration.
PORT=3000
NODE_ENV=development
BOT_API_TIMEOUT_MS=8000
DISCORD_API_TIMEOUT_MS=6500
DASHBOARD_OPTIONAL_LOOKUP_TIMEOUT_MS=1500

# Optional dashboard owner ID. OWNER_ID is preferred; the other names are aliases.
OWNER_ID=
BOT_OWNER_ID=
DASHBOARD_OWNER_ID=

# Optional direct Discord API fallback token. DISCORD_BOT_TOKEN is preferred;
# BOT_TOKEN and DISCORD_TOKEN are supported aliases.
DISCORD_BOT_TOKEN=
BOT_TOKEN=
DISCORD_TOKEN=

# Optional deployment version metadata. Railway supplies its own values automatically.
RAILWAY_GIT_COMMIT_SHA=
RAILWAY_DEPLOYMENT_ID=
SOURCE_VERSION=
GIT_COMMIT=

# Optional Playwright monitor configuration used by npm run monitor.
MONITOR_URL=http://localhost:3000
WEBSITE_URL=
PUBLIC_URL=

# Optional configuration used by node scripts/website-monitor.js.
MEOWZ_BASE_URL=http://localhost:3000
DISCORD_WEBHOOK_URL=
MONITOR_WAIT_MS=7000
MONITOR_SCREENSHOT_DIR=test-results/website-monitor
PLAYWRIGHT_HEADED=0
